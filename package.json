{
  "name": "skillit",
  "version": "0.0.0",
  "private": true,
  "description": "Compile-time generator of AI agent skills from your codebase. Inline docs, CLI definitions, config schemas, and examples compile into progressively disclosed SKILL.md files that any LLM can discover.",
  "license": "MIT",
  "author": "Pradeep Mouli <pmouli@mac.com> (https://github.com/pradeepmouli)",
  "repository": {
    "type": "git",
    "url": "https://github.com/pradeepmouli/skillit.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "pnpm -r --workspace-concurrency=1 run build",
    "dev": "vitest",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "type-check": "pnpm -r run type-check",
    "clean": "pnpm -r run clean",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "pnpm run build && changeset publish",
    "audit": "pnpm audit --audit-level moderate",
    "outdated": "pnpm outdated -r",
    "update:deps": "pnpm update -r --latest",
    "prepare": "simple-git-hooks",
    "docs": "typedoc --out docs/html --plugin typedoc-plugin-skillit",
    "docs:md": "typedoc"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^25.9.1",
    "@typescript/native-preview": "beta",
    "@vitest/coverage-v8": "5.0.0-beta.3",
    "lint-staged": "^17.0.5",
    "oxlint": "^1.67.0",
    "simple-git-hooks": "^2.13.1",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "5.0.0-beta.4"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged",
    "pre-push": "pnpm run type-check"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "oxfmt",
      "oxlint --fix"
    ],
    "*.{json,md}": [
      "oxfmt --no-error-on-unmatched-pattern"
    ]
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.1.3"
}
