{
  "name": "@skillit/client",
  "version": "0.4.0",
  "description": "The skillit CLI — generate, audit, and refine AI-agent skills from a TypeScript codebase, plus the Anthropic model client for the headless refine loop.",
  "license": "MIT",
  "author": "Pradeep Mouli",
  "repository": {
    "type": "git",
    "url": "https://github.com/pradeepmouli/skillit.git",
    "directory": "packages/client"
  },
  "bin": {
    "skillit": "./dist/bin.js"
  },
  "files": [
    "dist",
    "README.md",
    "skills"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "gen-cli-skill": "pnpm build && node scripts/gen-refine-cli-skill.mjs",
    "type-check": "tsgo --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.102.0",
    "@skillit/cli": "workspace:*",
    "@skillit/core": "workspace:*",
    "@skillit/mcp": "workspace:*",
    "@skillit/typedoc": "workspace:*",
    "commander": "^15.0.0"
  }
}
