{
  "name": "@skillit/core",
  "version": "2.0.0",
  "description": "Shared types, SKILL.md renderer, and token budgeting for skillit plugins",
  "keywords": [
    "agent-skills",
    "ai",
    "api-documentation",
    "documentation",
    "jsdoc",
    "llm",
    "llms-txt",
    "skill-generation",
    "skill-md",
    "skillit",
    "token-budgeting",
    "typedoc",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pradeepmouli/skillit.git",
    "directory": "packages/core"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/pradeepmouli"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "type-check": "tsgo --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@ast-grep/napi": "^0.43.0",
    "yaml": "^2.9.0"
  }
}
