{
  "name": "@skillit/mcp",
  "version": "0.3.0",
  "description": "Extract and bundle MCP servers as Agent Skills — introspects live MCP servers (stdio or HTTP) and produces SKILL.md consumable by MCP-native agents (via mcp: frontmatter) or non-MCP agents (via CLI-as-proxy adapters)",
  "keywords": [
    "agent-skills",
    "ai",
    "mcp",
    "model-context-protocol",
    "skill-generation",
    "skill-md",
    "skillit",
    "typescript"
  ],
  "license": "MIT",
  "author": "Pradeep Mouli",
  "repository": {
    "type": "git",
    "url": "https://github.com/pradeepmouli/skillit.git",
    "directory": "packages/mcp"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/pradeepmouli"
  },
  "files": [
    "dist",
    "README.md",
    "skills"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./adapter-utils": {
      "types": "./dist/adapter/cli-tools-helpers.d.ts",
      "import": "./dist/adapter/cli-tools-helpers.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "pretest:integration": "pnpm run build",
    "test:integration": "RUN_INTEGRATION_TESTS=true vitest run tests/integration"
  },
  "dependencies": {
    "@apidevtools/json-schema-ref-parser": "^15.3.5",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@skillit/core": "workspace:*",
    "@skillit/target-mcp-protocol": "workspace:*",
    "@types/json-schema": "^7.0.15",
    "commander": "^14.0.3",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@skillit/target-fastmcp": "workspace:*",
    "@skillit/target-mcpc": "workspace:*",
    "@types/node": "^25.9.1",
    "vitest": "^4.1.7"
  }
}
