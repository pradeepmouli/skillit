{
  "name": "@skillit/target-mcpc",
  "version": "0.2.0",
  "description": "mcpc CLI-as-proxy invocation-target adapter for @skillit/mcp — emits shell-command skills consumable by any agent with a shell tool, via Apify's mcpc CLI",
  "keywords": [
    "agent-skills",
    "ai",
    "mcp",
    "mcpc",
    "model-context-protocol",
    "skillit"
  ],
  "license": "MIT",
  "author": "Pradeep Mouli",
  "repository": {
    "type": "git",
    "url": "https://github.com/pradeepmouli/skillit.git",
    "directory": "packages/target-mcpc"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/pradeepmouli"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "type-check": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@skillit/core": "workspace:*",
    "@skillit/mcp": "workspace:*"
  },
  "devDependencies": {
    "@types/json-schema": "^7.0.15",
    "@types/node": "^25.9.1",
    "vitest": "^4.1.7",
    "yaml": "^2.9.0"
  }
}
