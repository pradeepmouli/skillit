{
  "name": "@skillit/typedoc",
  "version": "1.0.9",
  "description": "TypeDoc plugin that generates AI agent skills (SKILL.md) from TypeScript API documentation",
  "keywords": [
    "agent-skills",
    "ai",
    "api-documentation",
    "documentation",
    "jsdoc",
    "llm",
    "skill-generation",
    "skill-md",
    "skillit",
    "tsdoc",
    "typedoc",
    "typedoc-plugin",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pradeepmouli/skillit.git",
    "directory": "packages/typedoc"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/pradeepmouli"
  },
  "files": [
    "dist",
    "README.md",
    "skills"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "type-check": "tsgo --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@skillit/core": "workspace:*"
  },
  "devDependencies": {
    "typedoc": "^0.28.19"
  },
  "peerDependencies": {
    "typedoc": ">=0.28.0"
  }
}
